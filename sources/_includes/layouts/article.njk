<!DOCTYPE html>
<html lang="{{ lang or 'en' }}" xml:lang="{{ lang or 'en' }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ title }}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="../styles.css">
        {% if header_includes %}
            {{ header_includes | safe }}
        {% endif %}
    </head>
    <body>
        <div class="fixed-controls">
            {% if backlink %}
                <a href="{{ backlink }}" class="nav-link button-style">← back to main</a>
            {% endif %}
            {# <button id="toggle-code-outline-btn" class="button-style" title="Toggle code highlight">turn outlines off</button> #}
        </div>
        <header>
            <div class="header-content">
                <h1 class="big-headline">{{ headline or title }}</h1>
            </div>
        </header>
        <main>
            {% if intro_footer %}
                <footer>
                    {{ intro_footer | safe }}
                </footer>
            {% endif %}
            <article>
                {{ content | safe }}
            </article>
            {% if comments %}
                <section class="giscus-container">
                    <script src="https://giscus.app/client.js" data-repo="platonvin/platonvin.github.io" data-repo-id="R_kgDOMWEwPg" data-category="Announcements" data-category-id="DIC_kwDOMWEwPs4C0BKp" data-mapping="pathname" data-strict="0" data-reactions-enabled="1" data-emit-metadata="0" data-input-position="top" data-theme="light_high_contrast" data-lang="en" data-loading="lazy" crossorigin="anonymous" async></script>
                </section>
            {% endif %}
        </main>
        {% if after_body_script %}
            {{ after_body_script | safe }}
        {% endif %}
        <script>
            const btn = document.getElementById("toggle-code-outline-btn");
            if (btn) {
                btn.addEventListener("click", () => {
                    const noOutlines = document
                        .body
                        .classList
                        .toggle("no-code-outline");
                    btn.textContent = noOutlines
                        ? "turn outlines on"
                        : "turn outlines off";
                });
            }
        </script>
    </body>
</html>